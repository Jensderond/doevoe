# Copy this file to .env and fill in real values before running
# `docker compose up -d`. See README.md for what each of these means and
# for the full list of optional DOEVOE_* variables.

# EHLO hostname this server sends SMTP as. Must match the PTR (reverse DNS)
# record for DOEVOE_EGRESS_IP, or major receivers (Gmail, Outlook) will
# reject or junk your mail.
DOEVOE_HOSTNAME=mail.example.com

# The public IPv4 address this host sends outbound SMTP from. Used in the
# generated SPF record and to verify the PTR record points back here.
DOEVOE_EGRESS_IP=203.0.113.7

# Password for the /admin web UI (single admin account, no username).
DOEVOE_ADMIN_PASSWORD=change-me

# Mailbox that receives failure digests, rate alerts, monthly stats, and
# API-key lifecycle notifications.
DOEVOE_ADMIN_EMAIL=ops@example.com

# From address doevoe uses for its own notifications (failure digests, rate
# alerts, monthly stats, key created/revoked). The domain part must be one
# of the domains you verify in doevoe itself.
DOEVOE_SYSTEM_FROM=noreply@mail.example.com

# Public base URL used to build the deep links in doevoe's own notification
# emails (e.g. https://mail.example.com), i.e. the address of your
# TLS-terminating reverse proxy. Optional: defaults to
# "http://$DOEVOE_HOSTNAME" if unset, which is wrong once you're behind TLS.
# No trailing slash.
#DOEVOE_PUBLIC_URL=https://mail.example.com
